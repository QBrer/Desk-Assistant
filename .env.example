XIAOMI_API_KEY=your_xiaomi_mimo_api_key

# local = faster-whisper (offline, default); mimo = Xiaomi MiMo cloud audio transcription
LAIN_STT_PROVIDER=local
MIMO_ASR_MODEL=mimo-v2-omni

# Max response tokens for chat completions. Increase carefully: larger values are slower and cost more.
LAIN_MAX_TOKENS=32768
# Agent backend advanced default. App startup still defaults to MiMo; choose Hermes in the UI when needed.
LAIN_AGENT_BACKEND=mimo
LAIN_MIMO_MODEL=mimo-v2.5-pro
# Optional: only set this if the MiMo endpoint documents support for reasoning_effort.
LAIN_MIMO_REASONING_EFFORT=

DEEPSEEK_API_KEY=your_deepseek_api_key
LAIN_DEEPSEEK_BASE_URL=https://api.deepseek.com
LAIN_DEEPSEEK_MODEL=deepseek-v4-pro
LAIN_DEEPSEEK_REASONING_EFFORT=high
LAIN_DEEPSEEK_THINKING=enabled

LAIN_HERMES_BASE_URL=http://127.0.0.1:8642/v1
LAIN_HERMES_API_KEY=change-me-local-dev
LAIN_HERMES_MODEL=hermes-agent
